import os
from dotenv import load_dotenv
from langchain_community.utilities.sql_database import SQLDatabase
from langchain_core.prompts import PromptTemplate
from langchain_google_genai import ChatGoogleGenerativeAI

load_dotenv()

api_key = os.getenv("GOOGLE_API_KEY")

if not api_key:
    raise ValueError("GOOGLE_API_KEY not found in .env file")

llm = ChatGoogleGenerativeAI(
    model="gemini-2.5-flash",
    temperature=0,
    google_api_key=api_key
)

db = SQLDatabase.from_uri(
    "mysql+pymysql://root:YOURPASSWORD@localhost:3306/college_db"
)

sql_prompt = PromptTemplate(input_variables=["question", "schema"],template="""

You are an expert MySQL analyst.

Database Schema:
{schema}

Convert the question into ONE valid MySQL query.

Rules:
- Use only the tables and columns from the schema.
- Return ONLY raw SQL.
- Do NOT use markdown.
- Do NOT use ```sql.
- Do NOT explain anything.
- Generate exactly ONE SQL statement.
- If inserting multiple rows, use a single INSERT statement with multiple VALUES.

Question:
{question}
"""
)

schema = db.get_table_info()

question = "create a table for student marks"

response = llm.invoke(
    sql_prompt.format(
        question=question,
        schema=schema
    )
)

query = response.content.strip()

query = query.replace("```sql", "")
query = query.replace("```", "")
query = query.strip()

print("\nGenerated SQL:")
print(query)

try:
    result = db.run(query)

    print("\nResult:")
    print(result)

except Exception as e:
    print("\nError while executing SQL:")
    print(e)
